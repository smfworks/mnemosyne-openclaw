{
  "name": "mnemosyne-openclaw",
  "version": "1.1.0",
  "type": "module",
  "description": "100% offline, local SQLite memory plugin for OpenClaw. Replaces cloud memory with zero network dependency.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "workspace_md",
    "openclaw.plugin.json"
  ],
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.27"
  },
  "openclaw": {
    "plugin": "./openclaw.plugin.json",
    "extensions": [
      "./dist/index.js"
    ],
    "build": {
      "openclawVersion": ">=2026.4.27"
    },
    "compat": {
      "pluginApi": ">=2026.4.27"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "offline",
    "sqlite",
    "local"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smfworks/mnemosyne-openclaw.git"
  }
}
